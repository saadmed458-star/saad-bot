import axios from "axios";

const sentVideos = new Set();

export const NovaUltra = {
    command: "ايديت",
    category: "media",
    description: "🎬 جلب أفضل فيديو Anime Edit من TikTok.",
    usage: ".ايديت [اسم الأنمي]",
    elite: "off",
    group: false,
    prv: false,
    lock: "off"
};

export async function execute({ sock, msg }) {
    const chatId = msg.key.remoteJid;
    const body = msg.message?.extendedTextMessage?.text || msg.message?.conversation || "";
    const args = body.trim().split(/\s+/).slice(1);
    const query = args.join(" ");
    const searchText = query ? `anime edit ${query}` : "anime edit";

    // إرسال تفاعل للبوت
    await sock.sendMessage(chatId, { react: { text: "🎬", key: msg.key } });

    try {
        const { data } = await axios.get(
            `https://apis-starlights-team.koyeb.app/starlight/tiktoksearch?text=${encodeURIComponent(searchText)}`
        );

        const results = data.data;
        if (!results || results.length === 0) {
            return await sock.sendMessage(chatId, { text: "⚠️ لم يتم العثور على فيديوهات." }, { quoted: msg });
        }

        // فلترة الفيديوهات الجديدة فقط
        const fresh = results.filter(v => !sentVideos.has(v.nowm));
        if (fresh.length === 0) {
            return await sock.sendMessage(chatId, { text: "⚠️ لا يوجد فيديوهات جديدة الآن." }, { quoted: msg });
        }

        // ترتيب حسب الأكثر مشاهدة
        fresh.sort((a, b) => (b.play || 0) - (a.play || 0));
        const vid = fresh[0];
        sentVideos.add(vid.nowm);

        await sock.sendMessage(chatId, {
            video: { url: vid.nowm },
            caption: `*❐┃تم تنفيذ طلبك بنجاح┃✅*\n\n🎬 *Anime Edit:* ${query || "عشوائي"}`
        }, { quoted: msg });

    } catch (err) {
        console.error("❌ خطأ أثناء جلب الفيديو:", err.message);
        await sock.sendMessage(chatId, { text: "❌ حدث خطأ أثناء جلب الفيديو من TikTok." }, { quoted: msg });
    }
}