// Щ…ЩҶШҙЩҶ.js - Ш¶Ш№ЩҮ ЩҒЩҠ: plugins/elite/
import { jidDecode } from "@whiskeysockets/baileys";
import config from '../../nova/config.js';

const NovaUltra = {
    command: [ "Ш§Щ„ЩғЩ„" ],
    description: "Щ…ЩҶШҙЩҶ Ш¬Щ…ЩҠШ№ ШЈШ№Ш¶Ш§ШЎ Ш§Щ„Щ…Ш¬Щ…ЩҲШ№Ш© (Щ„Щ„Щ…ШҙШұЩҒЩҠЩҶ ЩҒЩӮШ·)",
    elite: "off",
    group: true,
    prv: false,
    lock: "off",
    admin: true
};

function decode(jid) {
    return (jidDecode(jid)?.user || jid.split("@")[0]) + "@s.whatsapp.net";
}

// ШҜШ§Щ„Ш© Ш§Щ„ШӘШӯЩӮЩӮ Щ…ЩҶ Ш§Щ„Щ…ШҙШұЩҒ
async function isGroupAdmin(sock, chatId, userId) {
    try {
        const groupMetadata = await sock.groupMetadata(chatId);
        const participant = groupMetadata.participants.find(p => p.id === userId);
        return participant?.admin === 'admin' || participant?.admin === 'superadmin';
    } catch {
        return false;
    }
}

// ШҜШ§Щ„Ш© Ш§Щ„ШұЩҠШЈЩғШӘ
async function sendReaction(sock, chatId, messageId, emoji) {
    try {
        await sock.sendMessage(chatId, {
            react: {
                text: emoji,
                key: {
                    remoteJid: chatId,
                    fromMe: true,
                    id: messageId
                }
            }
        });
    } catch (e) {}
}

async function execute({ sock, msg, args }) {
    const chatId = msg.key.remoteJid;
    const messageId = msg.key.id;
    const sender = decode(msg.key.participant || chatId);
    
    try {
        // Ш§Щ„ШӘШӯЩӮЩӮ Щ…ЩҶ ШЈЩҶ Ш§Щ„Щ…ШұШіЩ„ Щ…ШҙШұЩҒ
        const isAdmin = await isGroupAdmin(sock, chatId, sender);
        
        if (!isAdmin && !msg.key.fromMe) {
            await sendReaction(sock, chatId, messageId, "вҡ пёҸ");
            await sock.sendMessage(chatId, {
                text: "вқҢ *ЩҮШ°Ш§ Ш§Щ„ШЈЩ…Шұ Щ…ШӘШ§Шӯ ЩҒЩӮШ· Щ„Щ„Щ…ШҙШұЩҒЩҠЩҶ.*\n"
            }, { quoted: msg });
            return;
        }
        
        await sendReaction(sock, chatId, messageId, "вҸі");
        
        const groupMetadata = await sock.groupMetadata(chatId);
        const participants = groupMetadata.participants;
        const groupOwner = groupMetadata.owner;
        
        await sendReaction(sock, chatId, messageId, "вҡҷпёҸ");
        
        // ШӘШөЩҶЩҠЩҒ Ш§Щ„ШЈШ№Ш¶Ш§ШЎ
        const owner = [];
        const admins = [];
        const members = [];
        const ownerNumber = config.owner?.toString().replace(/\D/g, '') + "@s.whatsapp.net";
        
        for (const participant of participants) {
            const isOwner = participant.id === groupOwner || participant.id === ownerNumber;
            const isAdmin = participant.admin === 'admin' || participant.admin === 'superadmin';
            
            if (isOwner) owner.push(participant.id);
            else if (isAdmin) admins.push(participant.id);
            else members.push(participant.id);
        }
        
        const extraMsg = args.length > 0 ? args.join(" ") : "";
        const mentions = participants.map(p => p.id);
        
        await sendReaction(sock, chatId, messageId, "рҹ“Ө");
        
        // ШЁЩҶШ§ШЎ Ш§Щ„ШұШіШ§Щ„Ш©
        let tagMessage = "в•ӯв”Җв”Җв”ҖвңҰ *гҖҳ ШӘЩҖЩҖЩҖЩҶЩҖЩҖЩҖШЁЩҖЩҖЩҖЩҠЩҖЩҖЩҖЩҮ гҖҷ* вңҰв”Җв”Җв”Җв•®\n\n";
        tagMessage += "вң§в”Ғв”Ғв”Ғв”Ғв”Ғ вқҖ *Щ…ЩҖЩҖЩҖЩҶЩҖЩҖЩҖШҙЩҖЩҖЩҖЩҶ Ш§Щ„ЩҖЩҖЩҖЩғЩҖЩҖЩҖЩ„* вқҖ в”Ғв”Ғв”Ғв”Ғв”Ғвң§\n\n";
        
        if (extraMsg) {
            tagMessage += "рҹ“Ң *Ш§Щ„ШұШіШ§Щ„Ш©:*\nвҖң " + extraMsg + " вҖқ\n\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n";
        }
        
        tagMessage += "рҹ“Ҡ *Ш§Щ„ШҘШӯШөШ§ШҰЩҠШ§ШӘ:*\n";
        tagMessage += "рҹ‘‘ Ш§Щ„Щ…Ш§Щ„Щғ: " + owner.length + "\n";
        tagMessage += "рҹӣЎ Ш§Щ„Щ…ШҙШұЩҒЩҠЩҶ: " + admins.length + "\n";
        tagMessage += "рҹ‘Ҙ Ш§Щ„ШЈШ№Ш¶Ш§ШЎ: " + members.length + "\n";
        tagMessage += "рҹ“Ӣ Ш§Щ„ШҘШ¬Щ…Ш§Щ„ЩҠ: " + participants.length + "\n\n";
        tagMessage += "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n";
        
        // Ш№ШұШ¶ Ш§Щ„Щ…Ш§Щ„Щғ
        if (owner.length > 0) {
            tagMessage += "рҹ‘‘ *гҖҗ Ш§Щ„Щ…ЩҖЩҖШ§Щ„ЩҖЩҖЩғ гҖ‘*\n";
            tagMessage += "вң§в”Ғв”Ғв”Ғв”Ғв”Ғв”ҒвқҖв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғвң§\n";
            owner.forEach(id => {
                tagMessage += "в”Ј @" + id.split('@')[0] + "\n";
            });
            tagMessage += "вң§в”Ғв”Ғв”Ғв”Ғв”Ғв”ҒвқҖв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғвң§\n\n";
        }
        
        // Ш№ШұШ¶ Ш§Щ„Щ…ШҙШұЩҒЩҠЩҶ
        if (admins.length > 0) {
            tagMessage += "рҹӣЎ *гҖҗ Ш§Щ„ЩҖЩҖЩ…ЩҖЩҖШҙЩҖЩҖШұЩҒЩҖЩҖЩҠЩҖЩҖЩҶ гҖ‘*\n";
            tagMessage += "вң§в”Ғв”Ғв”Ғв”Ғв”Ғв”ҒвқҖв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғвң§\n";
            admins.forEach(id => {
                tagMessage += "в”Ј @" + id.split('@')[0] + "\n";
            });
            tagMessage += "вң§в”Ғв”Ғв”Ғв”Ғв”Ғв”ҒвқҖв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғвң§\n\n";
        }
        
        // Ш№ШұШ¶ Ш§Щ„ШЈШ№Ш¶Ш§ШЎ
        if (members.length > 0) {
            tagMessage += "рҹ‘Ҙ гҖҗ Ш§Щ„ШЈШ№ЩҖЩҖШ¶ЩҖЩҖШ§ШЎ гҖ‘\n";
            tagMessage += "вң§в”Ғв”Ғв”Ғв”Ғв”Ғв”ҒвқҖв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғвң§\n";
            
            const chunkSize = 30;
            for (let i = 0; i < members.length; i += chunkSize) {
                const chunk = members.slice(i, i + chunkSize);
                chunk.forEach(id => {
                    tagMessage += "в”Ј @" + id.split('@')[0] + "\n";
                });
            }
            tagMessage += "вң§в”Ғв”Ғв”Ғв”Ғв”Ғв”ҒвқҖв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғвң§\n\n";
        }
        
        tagMessage += "в•°в”Җв”Җв”ҖвңҰ *гҖҳ рқҗҖрқҗ§рқҗҡрқҗ¬рқҗӯрқҗҡрқҗ¬рқҗўрқҗҡ гҖҷ* вңҰв”Җв”Җв”Җв•Ҝ\n";
        tagMessage += "рҹ”” *ШӘЩ… Ш§Щ„ШӘЩҶШЁЩҠЩҮ ШЁЩҲШ§ШіШ·Ш©:* @" + sender.split('@')[0];
        
        await sock.sendMessage(chatId, {
            text: tagMessage,
            mentions: mentions
        }, { quoted: msg });
        
        await sendReaction(sock, chatId, messageId, "вң…");
        
    } catch (error) {
        console.error("вқҢ Ш®Ш·ШЈ:", error);
        await sendReaction(sock, chatId, messageId, "вқҢ");
        await sock.sendMessage(chatId, { 
            text: "вқҢ *ШӯШҜШ« Ш®Ш·ШЈ ШЈШ«ЩҶШ§ШЎ Щ…ШӯШ§ЩҲЩ„Ш© Щ…ЩҶШҙЩҶ Ш§Щ„ШЈШ№Ш¶Ш§ШЎ.*" 
        }, { quoted: msg });
    }
}

export default { NovaUltra, execute };